# ─────────────────────────────────────────────────────────────────────────────
# AI Financial OS — plantilla de configuración
# scripts/setup.ps1 copia este archivo a backend/.env automáticamente.
# Todas las variables tienen valores por defecto razonables: edita solo lo que
# necesites. Este archivo NO debe contener claves reales.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_URL=sqlite:///./data/financial.db
DUCKDB_PATH=./data/analytics.duckdb
# MI_SQLITE_PATH=./data/market_intelligence.db   # Market Intelligence (SQLite WAL)

# ── Asistente IA local (opcional) ────────────────────────────────────────────
# Proveedores locales: "ollama" o "lmstudio". Por defecto no se usa IA en la nube.
AI_ASSISTANT_ENABLED=true
AI_DEFAULT_PROVIDER=ollama
AI_DEFAULT_MODEL=qwen3-coder:30b
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
AI_REMOTE_PROVIDERS_ENABLED=false
AI_MAX_CONTEXT_TOKENS=32768
AI_MAX_OUTPUT_TOKENS=4096
AI_ENABLE_STREAMING=true
AI_ENABLE_TOOL_TRACE=true

# ── Proveedores de datos de mercado (opcionales, todos con free tier) ─────────
# Sin estas keys la app funciona con Yahoo Finance + Stooq. Añadirlas amplía la
# cobertura a acciones individuales y fundamentales. Regístrate y pega tu key:
#   Alpha Vantage           → https://www.alphavantage.co/support/#api-key
#   Finnhub                 → https://finnhub.io/register
#   Financial Modeling Prep → https://financialmodelingprep.com/register
#   Twelve Data             → https://twelvedata.com/pricing
#   Polygon                 → https://polygon.io/dashboard/signup
#   OpenFIGI                → https://www.openfigi.com/api
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
TWELVEDATA_API_KEY=
POLYGON_API_KEY=
OPENFIGI_API_KEY=

# ── Proveedores de datos macroeconómicos (opcionales, free tier) ─────────────
#   FRED  → https://fred.stlouisfed.org/docs/api/api_key.html
#   EIA   → https://www.eia.gov/opendata/register.php
#   AEMET → https://opendata.aemet.es/centrodedescargas/altaUsuario
FRED_API_KEY=
EIA_API_KEY=
AEMET_API_KEY=
