{
  "name": "ux-snapshot",
  "version": "1.0.0",
  "description": "UX snapshot tool for AI Financial OS — generates Playwright screenshots with mock data",
  "type": "module",
  "scripts": {
    "snapshots": "tsx run-ux-snapshots.ts",
    "snapshots:headed": "tsx run-ux-snapshots.ts --headed",
    "snapshots:real": "tsx run-ux-snapshots.ts --real",
    "snapshots:real:headed": "tsx run-ux-snapshots.ts --real --headed",
    "snapshots:responsive": "tsx run-ux-snapshots.ts --responsive",
    "snapshots:mercados": "tsx run-ux-snapshots.ts --filter=/markets",
    "snapshots:mercados:headed": "tsx run-ux-snapshots.ts --filter=/markets --headed",
    "e2e:flow-01-05": "tsx run-flow-01-05.ts",
    "e2e:flow-01-05:headed": "tsx run-flow-01-05.ts --headed",
    "e2e:flow-01-33": "tsx run-flow-01-05.ts",
    "e2e:flow-01-33:headed": "tsx run-flow-01-05.ts --headed",
    "test:flows": "tsx test-flow-contracts.ts",
    "test:negative-flows": "tsx test-negative-flow-contracts.ts",
    "test:e2e-isolation": "tsx test-e2e-data-location.ts",
    "report": "tsx report.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.49.0",
    "tsx": "^4.19.0",
    "yaml": "^2.9.0"
  }
}
