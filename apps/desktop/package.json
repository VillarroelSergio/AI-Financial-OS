{
  "name": "ai-financial-os-desktop",
  "private": true,
  "version": "1.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "ux:snapshots": "npm install --prefix ../../tools/ux-snapshot && npm run snapshots --prefix ../../tools/ux-snapshot",
    "ux:snapshots:headed": "npm install --prefix ../../tools/ux-snapshot && npm run snapshots:headed --prefix ../../tools/ux-snapshot",
    "ux:snapshots:real": "npm install --prefix ../../tools/ux-snapshot && npm run snapshots:real --prefix ../../tools/ux-snapshot",
    "ux:snapshots:real:headed": "npm install --prefix ../../tools/ux-snapshot && npm run snapshots:real:headed --prefix ../../tools/ux-snapshot",
    "ux:report": "npm run report --prefix ../../tools/ux-snapshot",
    "screenshot:mercados": "npm install --prefix ../../tools/ux-snapshot && npm run snapshots:mercados --prefix ../../tools/ux-snapshot",
    "screenshot:mercados:headed": "npm install --prefix ../../tools/ux-snapshot && npm run snapshots:mercados:headed --prefix ../../tools/ux-snapshot"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-shell": "^2.0.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
